# PostgreSQL / Redis
DATABASE_URL=postgresql://cpi_crm:cpi_crm_local@localhost:5433/cpi_crm
REDIS_URL=redis://localhost:6380

# Web/API
WEB_ORIGIN=http://localhost:3000
API_PORT=3001
NEXT_PUBLIC_API_BASE=/api
API_PROXY_TARGET=http://localhost:3001
ORGANIZATION_TIMEZONE=Asia/Novosibirsk
ARTIFACT_BASELINE_AT=2026-07-22T00:00:00.000Z

# OIDC (Keycloak local realm)
OIDC_ISSUER=http://localhost:8080/realms/cpi-crm
OIDC_CLIENT_ID=cpi-crm
OIDC_CLIENT_SECRET=local-only-change-me
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Generate for non-local use: openssl rand -base64 32
SESSION_KEY_BASE64=bG9jYWwtb25seS1zZXNzaW9uLWtleS0zMi1ieXRlcyE=
AUTH_REQUIRED=true

# S3-compatible private storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cpi-minio
S3_SECRET_KEY=cpi-minio-local-secret
S3_QUARANTINE_BUCKET=cpi-quarantine
S3_PRIVATE_BUCKET=cpi-private
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Workbook importer
# Relative paths are resolved from the workspace root.
IMPORT_WORKBOOK=./Участники_всех_мероприятий_Стартап_студии_ЯДРО1.xlsx
IMPORT_ACTOR_SUB=local-importer
