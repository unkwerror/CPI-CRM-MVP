{
	email {$ACME_EMAIL}
	servers {
		protocols h1 h2 h3
	}
}

{$CRM_DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

{$ID_DOMAIN} {
	encode zstd gzip
	reverse_proxy keycloak:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

# Only the S3 API is proxied. The MinIO administration console on :9001 stays
# private; object access still requires a short-lived signature.
{$S3_DOMAIN} {
	reverse_proxy minio:9000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
