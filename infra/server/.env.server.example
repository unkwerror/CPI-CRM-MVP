# Public hostnames. sslip.io resolves these names to 62.113.105.225.
CRM_DOMAIN=crm.62-113-105-225.sslip.io
ID_DOMAIN=id.62-113-105-225.sslip.io
S3_DOMAIN=files.62-113-105-225.sslip.io
ACME_EMAIL=CHANGE_ME@example.com
IMAGE_TAG=latest

# Main PostgreSQL database. Generate URL-safe secrets, for example:
# openssl rand -hex 32
POSTGRES_DB=cpi_crm
POSTGRES_USER=cpi_crm
POSTGRES_PASSWORD=CHANGE_ME_64_HEX

# Non-owner login used by API, worker, seed and importer.
APP_DB_USER=cpi_app
APP_DB_PASSWORD=CHANGE_ME_64_HEX

# Keycloak uses an isolated database and login.
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=CHANGE_ME_64_HEX
KEYCLOAK_ADMIN_USERNAME=crm-superadmin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# First CRM user, created only during the initial realm import. Keycloak asks
# this user to change the temporary password after the first login.
CRM_ADMIN_USERNAME=crm-admin
CRM_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
CRM_ADMIN_EMAIL=CHANGE_ME@example.com

# The same confidential-client secret is injected into Keycloak and the API.
OIDC_CLIENT_ID=cpi-crm
OIDC_CLIENT_SECRET=CHANGE_ME_64_HEX
# Must decode to exactly 32 bytes: openssl rand -base64 32
SESSION_KEY_BASE64=CHANGE_ME_BASE64_32_BYTES

# Private S3-compatible storage.
MINIO_ROOT_USER=cpi-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
S3_APP_USER=cpi-crm-app
S3_APP_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
S3_REGION=us-east-1
S3_QUARANTINE_BUCKET=cpi-quarantine
S3_PRIVATE_BUCKET=cpi-private

ORGANIZATION_TIMEZONE=Asia/Novosibirsk
ARTIFACT_BASELINE_AT=2026-07-22T00:00:00.000Z
LOG_LEVEL=info
WORKER_OUTBOX_BATCH_SIZE=5
WORKER_RECONCILIATION_BATCH_SIZE=100

# Path is resolved relative to infra/server/docker-compose.yml.
IMPORT_WORKBOOK_HOST=../../Участники_всех_мероприятий_Стартап_студии_ЯДРО1.xlsx
